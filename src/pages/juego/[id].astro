---
import { getCollection } from "astro:content";
// Variable de entorno desde el server
import { SHOW_SEE_MORE_BUTTON } from "astro:env/server";
import Layout from "../../layouts/Layout.astro";
import GameScore from "../../components/GameScore.astro";
import "../../styles/global.css";

// Definiendfo rutas dinamicas para poder acceder a cada pamtalla
export async function getStaticPaths() {
    const games = getCollection("games");

    // Se define el titulo de la pagina y el contenido como props
    return (await games).map((game) => ({
        params: { id: game.slug },
        props: { game },
    }));
}

// obtenemos los datos que se recbieron desde la coleccion indicada
const { game } = Astro.props;
// destructuramos el contenido del markdown
const { data, slug } = game;
const {
    genero,
    personajes,
    modo,
    escenarios,
    controles,
    actualizaciones,
    lanzamiento,
    img,
    plataforma,
    title,
    url,
    portadaImg,
    logo,
} = data;

const content = game.body;

// Indica que sera una pagina estatica
export const prerender = true;
---

<Layout title={`${title}`}>
    <div class="flex flex-col w-full relative" style="width: 100%;">
        <aside class="w-full absolute z-1">
            <img
                src={`/${portadaImg}`}
                alt={title}
                class="object-cover portada"
            />
        </aside>
        <aside
            class="w-full relative z-2 p-10 flex flex-row justify-between items-start"
            style="height: 450px;"
        >
            <a
                href="/"
                style={`background: url(/${img}); background-position: center; background-size: cover; background-repeat: no-repeat;`}
                class="image-container"
            >
                <img
                    src={`/${img}`}
                    alt={slug}
                    class="w-full h-full object-cover rounded-lg"
                />
            </a>
            <img
                class="relative object-contain w-75 logo"
                src={`/${logo}`}
                alt="logo"
            />
        </aside>
        <main
            class="z-2 pl-15 h-auto content-game-mk pb-20 flex flex-col justify-start items-start gap-2"
        >
            <h1
                class="text-left text-6xl font-extrabold text-white inline-block"
            >
                {title}
            </h1>

            <h2 class="text-left text-1xl font-bold text-white capitalize">
                Lanzamieto: {lanzamiento}
            </h2>

            <GameScore server:defer id={slug}>
                <!-- CARGA UN LOADER MIENTRAS EL SERVER ISLAND CARGA, IMPORTANTE EL FALLBACK -->
                <span slot="fallback" class="text-xs text-white font-semibold">Cargando puntuación...</span>
            </GameScore>

            <div
                class="content-description flex flex-row justify-between gap-10 mt-10"
            >
                <div class="half-description">
                    {
                        SHOW_SEE_MORE_BUTTON && (
                            <a
                                href={url}
                                target="_blank"
                                class="relative inline-flex items-center justify-center p-0.5 mb-2 me-2 overflow-hidden text-md font-bold text-gray-900 rounded-lg group bg-gradient-to-br from-pink-500 to-orange-400 group-hover:from-pink-500 group-hover:to-orange-400 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-pink-200 dark:focus:ring-pink-800 w-50 cursor-pointer"
                            >
                                <span class="relative px-5 py-2.5 transition-all w-full ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-transparent group-hover:dark:bg-transparent gap-3 flex flex-row justify-center items-center">
                                    Saber mas
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="1em"
                                        height="1em"
                                        viewBox="0 0 128 128"
                                    >
                                        <>
                                            <path
                                                fill="#84B0C1"
                                                d="M23.91 104.02c-6.5-6.63-6.5-17.21 0-23.84l18.74-18.74c2.04-2.04 4.72-3.57 7.52-4.33s5.74-.76 8.41-.13c2.8.76 5.48 2.17 7.65 4.21l.25.25c6.63 6.63 6.63 17.21 0 23.84l-18.74 18.74c-6.62 6.63-17.33 6.63-23.83 0m53.03-53.03c-12.36-12.36-32.63-12.36-45 0L13.33 69.73c-12.36 12.36-12.36 32.63 0 45s32.63 12.36 45 0l18.74-18.74c12.23-12.37 12.23-32.63-.13-45"
                                            />
                                            <path
                                                fill="#2F7889"
                                                d="M66.86 48.48c3.36-1.69 6.57-.51 6.57-.51c-6.94-5.13-14.51-6.59-21.03-6.18c-.04.05-.07.1-.11.16c-2.86 4.39-3.5 10.19-1.72 15.07c2.68-.66 5.46-.64 8-.03c1.04.28 1.83.55 3.39 1.28c.01-.01-.54-7.05 4.9-9.79m-20.1 9.98c.13-.97.19-1.95.25-2.93c.28-4.22 1-8.42 2.14-12.49c.08-.29.16-.6.24-.91c-3.09.49-6.12 1.43-8.97 2.83c-4.44 5.73-2.98 13.15 2.23 16.49c1.19-1.19 2.59-2.2 4.11-2.99"
                                            />
                                            <path
                                                fill="#84B0C1"
                                                d="M104.09 23.98c6.5 6.63 6.5 17.21 0 23.84L85.35 66.56c-2.04 2.04-4.72 3.57-7.52 4.33s-5.74.76-8.41.13c-2.8-.76-5.48-2.17-7.65-4.21l-.25-.25c-6.63-6.63-6.63-17.21 0-23.84l18.74-18.74c6.62-6.63 17.33-6.63 23.83 0M51.06 77.01c12.36 12.36 32.63 12.36 45 0l18.61-18.74c12.36-12.36 12.36-32.63 0-45s-32.63-12.36-45 0L50.94 32.01c-12.24 12.37-12.24 32.63.12 45"
                                            />
                                            <path
                                                fill="#A8E3F0"
                                                d="M50.45 39.42c.04-.03.08-.07.12-.1c.53-.46 1.12-.9 1.81-1.02s1.5.19 1.74.85c.18.49.02 1.03-.15 1.52c-2.63 7.95-4.74 18.04-2.18 26.27c.25.8.49 1.83-.18 2.33c-.39.3-.97.25-1.4.02c-4.7-2.54-5.52-9.42-5.74-14.14c-.26-5.96 1.39-11.7 5.98-15.73"
                                            />
                                            <path
                                                fill="#2F7889"
                                                d="M71.32 71.34c-.64-.08-1.32-.21-1.32-.21s-.1 4.27-3.51 7.81c-3.78 3.92-7.55 3.82-7.55 3.82c1.99 1.15 5.96 2.34 7.4 2.68l.15-.15c3.83-3.84 5.43-9 4.83-13.95m19.44-10.19l-5.33 5.33c1.33 5.94.97 12.18-1.09 17.94c2.59-.92 5.08-2.19 7.4-3.8c3.83-6.56 2.99-14.31-.98-19.47"
                                            />
                                            <path
                                                fill="#A8E3F0"
                                                d="M79.89 70.01c-.63-1.59-1.86-3.2-3.4-3.05c-.96.09-2.45.99-2.35 3.74c.07 2.13.88 4.21-.28 7c-1.7 4.08-1.31 5.18-.9 5.83c.45.71 1.28 1.03 2.05 1.02c2.03-.01 3.71-1.87 4.63-3.91c1.49-3.26 1.58-7.29.25-10.63m-30.64 38.17c.64-.53 2.3-2.3 3.07-1.18c-.28 3.08-2.65 5.59-5.25 7.27c-3.2 2.07-6.99 3.29-10.8 3.18c-3.16-.09-8.4-1.37-10.24-4.3c-1.5-2.38 1.67-2.79 3.43-2.13c6.27 2.39 13.36 2.44 19.79-2.84"
                                            />
                                        </>
                                    </svg>
                                </span>
                            </a>
                        )
                    }
                    <p
                        class="text-left font-semibold text-lg text-white mt-3 prose"
                    >
                        {content}
                    </p>
                </div>
                <div class="half-description gap-3">
                    <h2
                        class="text-left text-2xl font-bold text-white mb-5 capitalize"
                    >
                        Detalles del juego
                    </h2>
                    <p
                        class="text-left font-semibold text-pretty text-white capitalize"
                    >
                        <span class="font-extrabold tit-desc">Genero:</span>
                        {genero}
                    </p>
                    <p
                        class="text-left font-semibold text-pretty text-white capitalize"
                    >
                        <span class="font-extrabold tit-desc">Personajes:</span>
                        {personajes}
                    </p>
                    <p
                        class="text-left font-semibold text-pretty text-white capitalize"
                    >
                        <span class="font-extrabold tit-desc">Modo:</span>
                        {modo}
                    </p>
                    <p
                        class="text-left font-semibold text-pretty text-white capitalize"
                    >
                        <span class="font-extrabold tit-desc">Escenarios:</span>
                        {escenarios}
                    </p>
                    <p
                        class="text-left font-semibold text-pretty text-white capitalize"
                    >
                        <span class="font-extrabold tit-desc">Controles:</span>
                        {controles}
                    </p>
                    <p
                        class="text-left font-semibold text-pretty text-white capitalize"
                    >
                        <span class="font-extrabold tit-desc"
                            >Actualizaciones:</span
                        >
                        {actualizaciones}
                    </p>
                    <p
                        class="text-left font-semibold text-pretty text-white capitalize"
                    >
                        <span class="font-extrabold tit-desc">Plataforma:</span>
                        {plataforma}
                    </p>
                </div>
            </div>
        </main>
    </div>
</Layout>

<style>
    @reference "tailwindcss";

    .portada {
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        object-position: top;
        mask-image: linear-gradient(#000 30%, transparent);
    }

    .image-container {
        @apply relative inline-block w-35 h-50 mb-2.5 mr-10 rounded-lg transition-all duration-300 delay-150;
        aspect-ratio: 2/3;
        box-shadow: 0 0 50px #ffffff25;

        &:hover {
            transform: scale(1.1);
        }

        &::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: inherit;
            filter: blur(25px) saturate(1.5);
            transform: scale(1.05);
            z-index: -1;
            aspect-ratio: 2/3;
        }
    }

    .logo {
        filter: drop-shadow(0 0 10px #ffffff75);
    }

    .shadow {
        position: absolute;
        top: 0;
        background: linear-gradient(to bottom, transparent, #000);
    }

    .content-game-mk {
        position: relative;

        h1 {
            /* -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            color: transparent;
            -webkit-text-stroke: 0.0001px #fff; */
            filter: drop-shadow(0 0 15px #ffffff);
        }

        .half-description {
            @apply flex flex-col justify-start items-start w-1/2;

            .tit-desc {
                @apply bg-gradient-to-tr from-blue-500 via-purple-600 to-red-600;
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }
        }
    }
</style>