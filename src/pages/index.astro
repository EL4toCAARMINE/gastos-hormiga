---
import Layout from '../layouts/Layout.astro';
import About from '../components/Card.astro';
// importante es llamar tailwind aqui desde el css 
import "../styles/global.css";

import { getCollection } from 'astro:content';

const games = await getCollection('games');
---

<Layout>
	<main>
		<h1 class="text-white text-center text-6xl font-extrabold mb-20">💸Gastos <span class="bg-gradient-to-r from-purple-500 via-pink-400 to-white">Pendejos</span> En Steam💸</h1>

		<section aria-label="Pero como son juegazos no me arrepiento">
			<div class="px-4 mx-auto max-w-full-screen-xl">
				<div class="grid gap-6 md:grid-cols-2">
					{
						games.map(game=>{
							const {slug, data, body} = game;
							const {genero, personajes, modo, escenarios, controles, actualizaciones, lanzamiento, img, plataforma, title, url} = data;
							
							return (
								<article class="flex">
									<a href={`/juego/${slug}`} class="mb-2 xl:mb-0 transition-all delay-150 duration-300 ease inline-block hover:scale-110 overflow-hidden w-50 h-75 mr-10 rounded-lg image-container">
										<img src={`/${img}`} alt={slug} class="w-full object-cover h-full"/💸>
									</a>
									<div class="flex flex-col justify-center">
										<h2 class="mb-2 text-2xl font-bold leading-tight text-white">{title}</h2>

										<p class="mb-4 text-gray-300 max-w-sm">{genero}</p>
										<span class="text-xs">{plataforma}</span>
									</div>
								</article>
							)
						})
					}
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	span{
		-webkit-background-clip: text;
    	-webkit-text-fill-color: transparent;
	}

	.image-container{
		box-shadow: 0 0 100px #ffffff60;
	}
</style>